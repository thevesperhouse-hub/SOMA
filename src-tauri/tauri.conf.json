{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SOMA",
  "version": "0.1.0",
  "identifier": "com.soma.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SOMA",
        "width": 1340,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
